# ============================================================
# NanoClaw 환경변수 설정
# 복사 후 실제 값으로 변경: cp .env.example .env && vi .env
# ============================================================

# Slack Bot Token (OAuth & Permissions에서 발급)
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN

# Slack App Token (Socket Mode 활성화 시 발급, xapp-로 시작)
SLACK_APP_TOKEN=xapp-YOUR-APP-TOKEN

# Slack 채널 ID
SLACK_CHANNEL_ID=C0AKQDRG7EH

# ── Token Rotation (선택사항, 미설정 시 고정 토큰 모드) ──
# Slack App > Basic Information > App Credentials 에서 확인
# SLACK_CLIENT_ID=your-client-id
# SLACK_CLIENT_SECRET=your-client-secret
# SLACK_REFRESH_TOKEN=your-refresh-token

# ── 주간 동기화 스케줄 ──
# 요일 (0=월, 1=화, ..., 6=일)
NANOCLAW_SYNC_DAY=0
# 시간 (24시간제)
NANOCLAW_SYNC_HOUR=9
# 동기화 대상 국가 (쉼표 구분)
NANOCLAW_SYNC_COUNTRIES=KR,US,JP,DE,GB,FR,AU
